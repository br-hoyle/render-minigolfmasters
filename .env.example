# Database (Supabase PostgreSQL)
DATABASE_URL=                   # Session pooler URL from Supabase → Project Settings → Database

# Auth
JWT_SECRET_KEY=                 # Generate with: openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=72

# Email
ADMIN_EMAIL=                    # Email address to receive admin notifications (e.g. new user signups)
GMAIL_FROM_EMAIL=               # Email address to send emails from (must be a Gmail address)
GMAIL_CLIENT_ID=                # Google Cloud Console → Credentials → OAuth 2.0 Client IDs
GMAIL_CLIENT_SECRET=            # Google Cloud Console → Credentials → OAuth 2.0 Client IDs
GMAIL_REFRESH_TOKEN=            # Generate with: https://developers.google.com/oauthplayground/ → Select Gmail API v1 → https://mail.google.com/ scope → Authorize & Exchange for tokens

# App
ENVIRONMENT=development         # or production
FRONTEND_URL=                   # e.g. https://minigolfmasters.onrender.com

# Frontend (Vite) — put in frontend/.env
VITE_API_URL=                   # e.g. https://minigolfmasters-api.onrender.com
